#!/usr/bin/env python3
"""Scaffold a new project by cloning a template repository.

Behavior:
1) Clone template repo to /Tmp/hassicir/Projects/<name>
2) Remove inherited .git
3) Apply project-specific setup (config name + README title)
4) Optionally write CUDA_VISIBLE_DEVICES into .env
5) Initialize a fresh git repo
"""

from __future__ import annotations

import argparse
import os
import shutil
import subprocess
import sys
from pathlib import Path

PROJECTS_ROOT = Path("/Tmp/hassicir/Projects")
GPU_CONFIG_PATH = Path("/Tmp/hassicir/ai-research/gpu.conf")
DEFAULT_TEMPLATE_REPO_URL = "git@github.com:RayanZaki/Research_experiment_env.git"


def run(cmd: list[str], cwd: str | None = None) -> None:
    subprocess.run(cmd, cwd=cwd, check=True)


def run_capture(cmd: list[str], cwd: str | None = None) -> str:
    return subprocess.run(
        cmd,
        cwd=cwd,
        text=True,
        capture_output=True,
        check=True,
    ).stdout.strip()


def detect_gpus() -> list[str]:
    try:
        out = subprocess.check_output(
            [
                "nvidia-smi",
                "--query-gpu=index,name,memory.total",
                "--format=csv,noheader,nounits",
            ],
            text=True,
            timeout=5,
        )
        return [x.strip() for x in out.splitlines() if x.strip()]
    except Exception:
        return []


def load_gpu_config() -> str | None:
    if not GPU_CONFIG_PATH.exists():
        return None
    for line in GPU_CONFIG_PATH.read_text().splitlines():
        if line.startswith("CUDA_VISIBLE_DEVICES="):
            return line.split("=", 1)[1].strip()
    return None


def save_gpu_config(value: str) -> None:
    GPU_CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
    GPU_CONFIG_PATH.write_text(f"CUDA_VISIBLE_DEVICES={value}\n")


def prompt_gpu_selection() -> str | None:
    gpus = detect_gpus()
    current = load_gpu_config()

    if current:
        print(f"\n  Current CUDA_VISIBLE_DEVICES = {current}")

    if not gpus:
        value = input("  No GPUs detected. Enter CUDA_VISIBLE_DEVICES (or Enter to skip): ").strip()
        if value:
            save_gpu_config(value)
            return value
        return current

    print("\n  Available GPUs:")
    for line in gpus:
        parts = [p.strip() for p in line.split(",")]
        idx, name = parts[0], parts[1]
        mem = parts[2] if len(parts) > 2 else "?"
        print(f"    [{idx}] {name} ({mem} MiB)")

    prompt = "  Enter GPU ids (e.g. 0,1)"
    if current:
        prompt += f" [current: {current}]"
    prompt += ": "

    value = input(prompt).strip()
    if value:
        save_gpu_config(value)
        return value
    return current


def write_env_file(project_dir: Path, cuda_devices: str | None) -> None:
    env_path = project_dir / ".env"
    lines = []
    if env_path.exists():
        lines = [
            line
            for line in env_path.read_text().splitlines(keepends=True)
            if not line.startswith("CUDA_VISIBLE_DEVICES=")
        ]

    if cuda_devices:
        lines.insert(0, f"CUDA_VISIBLE_DEVICES={cuda_devices}\n")
    if not any("WANDB_API_KEY" in line for line in lines):
        lines.append("WANDB_API_KEY=\n")

    env_path.write_text("".join(lines))


def set_yaml_scalar(file_path: Path, section: str, field: str, value: str) -> None:
    if not file_path.exists():
        return

    lines = file_path.read_text().splitlines(keepends=True)
    current_top = None

    for i, line in enumerate(lines):
        stripped = line.strip()
        if stripped.endswith(":") and not line.startswith((" ", "\t")):
            current_top = stripped[:-1]
            continue

        if current_top == section and stripped.startswith(f"{field}:"):
            indent = line[: len(line) - len(line.lstrip(" \t"))]
            lines[i] = f"{indent}{field}: {value}\n"
            break

    file_path.write_text("".join(lines))


def apply_project_setup(project_dir: Path, project_name: str) -> None:
    cfg = project_dir / "configs" / "default.yaml"
    set_yaml_scalar(cfg, "project", "name", project_name)
    set_yaml_scalar(cfg, "wandb", "project", project_name)

    readme = project_dir / "README.md"
    if readme.exists():
        lines = readme.read_text().splitlines(keepends=True)
        if lines and lines[0].startswith("# "):
            lines[0] = f"# {project_name}\n"
            readme.write_text("".join(lines))


def clone_template(repo: str, target_dir: Path) -> None:
    if target_dir.exists() and any(target_dir.iterdir()):
        raise FileExistsError(f"Target directory is not empty: {target_dir}")
    if target_dir.exists() and not any(target_dir.iterdir()):
        target_dir.rmdir()

    target_dir.parent.mkdir(parents=True, exist_ok=True)
    run(["git", "clone", "--depth", "1", repo, str(target_dir)])

    inherited_git = target_dir / ".git"
    if inherited_git.exists():
        shutil.rmtree(inherited_git)


def detect_default_template_repo() -> str:
    env_value = os.environ.get("CREATE_PROJECT_TEMPLATE_REPO")
    if env_value:
        return env_value

    script_dir = Path(__file__).resolve().parent
    try:
        toplevel = run_capture(["git", "rev-parse", "--show-toplevel"], cwd=str(script_dir))
        if toplevel:
            return toplevel
    except Exception:
        pass

    return DEFAULT_TEMPLATE_REPO_URL


def init_git_repo(project_dir: Path) -> None:
    run(["git", "init"], cwd=str(project_dir))
    run(["git", "add", "."], cwd=str(project_dir))
    try:
        run(["git", "commit", "-m", "Initial project scaffold"], cwd=str(project_dir))
    except subprocess.CalledProcessError:
        print("  Git repo initialized (commit skipped: configure git user.name/user.email)")


def main() -> int:
    default_repo = detect_default_template_repo()

    parser = argparse.ArgumentParser(
        description="Create a project by cloning a template repo.",
        epilog=(
            "Examples:\n"
            "  create_project my_project\n"
            "  create_project my_project --repo https://github.com/owner/repo.git\n"
            "  create_project my_project --gpus 0,1\n"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("name", help="Project name or nested path")
    parser.add_argument(
        "--repo",
        default=default_repo,
        help=(
            "Template repository URL/path "
            "(default: CREATE_PROJECT_TEMPLATE_REPO, else enclosing git repo, else canonical template URL)"
        ),
    )

    gpu_group = parser.add_mutually_exclusive_group()
    gpu_group.add_argument("--no-gpu", action="store_true", help="Skip GPU prompt")
    gpu_group.add_argument("--gpus", metavar="IDS", help="Set CUDA_VISIBLE_DEVICES directly")

    args = parser.parse_args()

    project_name = Path(args.name).name
    project_dir = PROJECTS_ROOT / args.name

    cuda_devices = None
    if args.gpus:
        save_gpu_config(args.gpus)
        cuda_devices = args.gpus
        print(f"  CUDA_VISIBLE_DEVICES set to {cuda_devices}")
    elif args.no_gpu:
        print("  GPU prompt skipped — all GPUs allowed")
    else:
        cuda_devices = prompt_gpu_selection()

    clone_template(args.repo, project_dir)
    apply_project_setup(project_dir, project_name)

    if cuda_devices:
        write_env_file(project_dir, cuda_devices)

    init_git_repo(project_dir)

    print(f"\nProject created at: {project_dir}\n")
    return 0


if __name__ == "__main__":
    sys.exit(main())
