PROJECTS_ROOT = os.path.expanduser("/Tmp/hassicir/Projects")

# Path to the global GPU config file (shared across all projects)
GPU_CONFIG_PATH = "/Tmp/hassicir/ai-research/gpu.conf"


def detect_gpus() -> list[str]:
    """Return a list of GPU info lines via nvidia-smi."""
    try:
        result = subprocess.run(
            ["nvidia-smi", "--query-gpu=index,name,memory.total",
             "--format=csv,noheader,nounits"],
            capture_output=True, text=True, timeout=5,
        )
        if result.returncode == 0 and result.stdout.strip():
            return result.stdout.strip().splitlines()
    except (FileNotFoundError, subprocess.TimeoutExpired):
        pass
    return []


def load_gpu_config() -> str | None:
    """Load the saved CUDA_VISIBLE_DEVICES value, or None if not set."""
    if os.path.exists(GPU_CONFIG_PATH):
        with open(GPU_CONFIG_PATH, "r") as f:
            for line in f:
                line = line.strip()
                if line.startswith("CUDA_VISIBLE_DEVICES="):
                    return line.split("=", 1)[1]
    return None


def save_gpu_config(value: str):
    """Save CUDA_VISIBLE_DEVICES to the global config file."""
    os.makedirs(os.path.dirname(GPU_CONFIG_PATH), exist_ok=True)
    with open(GPU_CONFIG_PATH, "w") as f:
        f.write(f"CUDA_VISIBLE_DEVICES={value}\n")
    print(f"  GPU config saved to {GPU_CONFIG_PATH}")


def prompt_gpu_selection():
    """Interactively prompt the user to select GPUs.

    Returns the CUDA_VISIBLE_DEVICES string (e.g. "0,1") or None to skip.
    """
    gpus = detect_gpus()

    current = load_gpu_config()
    if current is not None:
        print(f"\n  Current CUDA_VISIBLE_DEVICES = {current}")

    if not gpus:
        print("\n  No NVIDIA GPUs detected (nvidia-smi not found or no GPUs).")
        value = input("  Enter CUDA_VISIBLE_DEVICES manually (or press Enter to skip): ").strip()
        if value:
            save_gpu_config(value)
            return value
        return current

    print("\n  Available GPUs:")
    for line in gpus:
        parts = [p.strip() for p in line.split(",")]
        idx, name = parts[0], parts[1]
        mem = parts[2] if len(parts) > 2 else "?"
        print(f"    [{idx}] {name}  ({mem} MiB)")

    prompt = "  Enter GPU ids to use (comma-separated, e.g. 0,1)"
    if current is not None:
        prompt += f" [current: {current}]"
    prompt += ": "

    value = input(prompt).strip()
    if not value and current is not None:
        return current  # keep existing
    if value:
        save_gpu_config(value)
        return value
    return current


def write_env_file(base_path: str, cuda_devices: str | None):
    """Write a .env file with CUDA_VISIBLE_DEVICES into the project."""
    env_path = os.path.join(base_path, ".env")
    lines = []
    if os.path.exists(env_path):
        with open(env_path, "r") as f:
            lines = [l for l in f.readlines()
                     if not l.startswith("CUDA_VISIBLE_DEVICES=")]

    if cuda_devices is not None:
        lines.insert(0, f"CUDA_VISIBLE_DEVICES={cuda_devices}\n")

    # Add WANDB_API_KEY placeholder if not already present
    if not any("WANDB_API_KEY" in l for l in lines):
        lines.append("WANDB_API_KEY=\n")

    with open(env_path, "w") as f:
        f.writelines(lines)


def main():
    parser = argparse.ArgumentParser(
        description="Create an AI research project folder structure.",
        epilog="Examples:\n"
               "  create_project my_project\n"
               "  create_project NLP/sentiment --no-gpu\n"
               "  create_project my_project --gpus 0,1\n",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("name",
                        help="Project name or path (e.g. 'my_project' or 'NLP/sentiment_analysis')")
    gpu_group = parser.add_mutually_exclusive_group()
    gpu_group.add_argument("--no-gpu", action="store_true",
                           help="Skip GPU prompt, use all available GPUs (no restriction)")
    gpu_group.add_argument("--gpus", metavar="IDS",
                           help="Set CUDA_VISIBLE_DEVICES directly (e.g. '0,1')")
    args = parser.parse_args()

    project_name = os.path.basename(args.name)
    base = os.path.join(PROJECTS_ROOT, args.name)
    os.makedirs(base, exist_ok=True)

    # ── GPU selection ──
    cuda_devices = None
    if args.gpus:
        save_gpu_config(args.gpus)
        cuda_devices = args.gpus
        print(f"  CUDA_VISIBLE_DEVICES set to {cuda_devices}")
    elif args.no_gpu:
        print("  GPU prompt skipped — all available GPUs will be used")
    else:
        cuda_devices = prompt_gpu_selection()

    # ── Create project ──
    create_structure(base, STRUCTURE)
    write_templates(base, project_name)
    write_root_files(base)

    if cuda_devices is not None:
        write_env_file(base, cuda_devices)

    # ── Git init ──
    git_dir = os.path.join(base, ".git")
    if not os.path.exists(git_dir):
        subprocess.run(["git", "init", base], capture_output=True)
        subprocess.run(["git", "-C", base, "add", "."], capture_output=True)
        subprocess.run(
            ["git", "-C", base, "commit", "-m", "Initial project structure"],
            capture_output=True,
        )
        print(f"  Git repository initialized with initial commit")

    # ── Print tree ──
    print(f"\nProject created at: {base}\n")
    for root, dirs, files in os.walk(base):
        if ".git" in dirs:
            dirs.remove(".git")
        level = root.replace(base, "").count(os.sep)
        indent = "  " * level
        print(f"{indent}{os.path.basename(root)}/")


if __name__ == "__main__":
